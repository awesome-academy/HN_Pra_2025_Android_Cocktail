<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/imgstart"
    android:padding="@dimen/dp_16">

    <LinearLayout
        android:id="@+id/searchHeader"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="@dimen/dp_0"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_box_dark"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/dp_12">

            <ImageView
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:src="@drawable/ic_search"
                android:tint="@color/gray_300"
                android:layout_marginEnd="@dimen/dp_8" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="@string/Search"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_400"
                android:inputType="text"
                android:imeOptions="actionSearch" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnFilter"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_48"
            android:layout_marginStart="@dimen/dp_8"
            android:background="@drawable/bg_circle_primary"
            android:src="@drawable/ic_filter_list"
            android:scaleType="centerInside"
            android:padding="@dimen/dp_12"
            android:tint="@color/white" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/searchResultsContainer"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_0"
        android:layout_weight="1"
        android:orientation="vertical">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingVertical="@dimen/dp_12"
            android:paddingBottom="@dimen/dp_72" />

        <LinearLayout
            android:id="@+id/layoutPagination"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_60"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/dp_12"
            android:background="@android:color/transparent"
            android:elevation="@dimen/dp_4"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btnPrevious"
                android:layout_width="@dimen/dp_36"
                android:layout_height="@dimen/dp_36"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/dp_8"
                android:enabled="false"
                android:alpha="0.5"
                android:layout_marginEnd="@dimen/dp_8"
                android:tint="@color/white"
                android:scaleType="centerInside" />

            <LinearLayout
                android:id="@+id/layoutPageNumbers"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_36"
                android:orientation="horizontal"
                android:gravity="center" />

            <ImageView
                android:id="@+id/btnNext"
                android:layout_width="@dimen/dp_36"
                android:layout_height="@dimen/dp_36"
                android:src="@drawable/ic_arrow_right"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/dp_8"
                android:enabled="false"
                android:alpha="0.5"
                android:layout_marginStart="@dimen/dp_8"
                android:tint="@color/white"
                android:scaleType="centerInside" />

        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/detailContainer"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_0"
        android:layout_weight="1"
        android:visibility="gone" />
</LinearLayout>
