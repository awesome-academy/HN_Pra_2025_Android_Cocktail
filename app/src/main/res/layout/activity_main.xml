<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_view"
        android:layout_width="@dimen/dp_0"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_0"
        android:layout_marginEnd="@dimen/dp_0"
        android:background="?android:attr/windowBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:menu="@menu/bottom_nav_menu" />

    <fragment
        android:id="@+id/nav_host_fragment_activity_main"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/custom_nav_bar"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navGraph="@navigation/mobile_navigation" />

    <!-- Custom Navigation Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/custom_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_72"
        android:background="@drawable/navbar_background"
        android:elevation="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Home Button -->
        <ImageView
            android:id="@+id/nav_home"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_48"
            android:layout_marginStart="@dimen/dp_32"
            android:background="@drawable/nav_item_background"
            android:padding="@dimen/dp_12"
            android:src="@drawable/ic_home_black_24dp"
            android:contentDescription="@string/title_home"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Messages Button -->
        <ImageView
            android:id="@+id/nav_messages"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_48"
            android:layout_marginStart="@dimen/dp_16"
            android:background="@drawable/nav_item_background"
            android:padding="@dimen/dp_12"
            android:src="@drawable/ic_notifications_black_24dp"
            android:contentDescription="@string/title_messages"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/nav_home"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Center Add Button (Highlighted) -->
        <FrameLayout
            android:id="@+id/nav_add_container"
            android:layout_width="@dimen/dp_64"
            android:layout_height="@dimen/dp_64"
            android:layout_marginBottom="@dimen/dp_8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/nav_add"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/nav_add_button_background"
                android:padding="@dimen/dp_16"
                android:src="@drawable/ic_add"
                android:contentDescription="@string/title_add"
                android:clickable="true"
                android:focusable="true" />
        </FrameLayout>

        <!-- Favorites Button -->
        <ImageView
            android:id="@+id/nav_favorites"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_48"
            android:layout_marginEnd="@dimen/dp_16"
            android:background="@drawable/nav_item_background"
            android:padding="@dimen/dp_12"
            android:src="@drawable/ic_heart"
            android:contentDescription="@string/title_favorites"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/nav_profile"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Profile Button -->
        <ImageView
            android:id="@+id/nav_profile"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_48"
            android:layout_marginEnd="@dimen/dp_32"
            android:background="@drawable/nav_item_background"
            android:padding="@dimen/dp_12"
            android:src="@drawable/ic_profile"
            android:contentDescription="@string/title_profile"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

